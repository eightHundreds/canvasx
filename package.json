{
  "name": "canvasx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "canvas:dev": "vite",
    "build": "tsc -b && vite build && pnpm build:umd",
    "build:umd": "vite build --config vite.lib.config.ts && node scripts/sync-skill-runtime.mjs",
    "canvas:check": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:html": "node skills/canvasx/scripts/validate_canvas.mjs examples/single-file-report.html",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.5",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
